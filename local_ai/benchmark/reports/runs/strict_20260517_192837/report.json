      "extracted_code": "#include <stdio.h>\n#include <math.h>\n\nint main(void) {\n    double x[4], y[4];\n    for (int i = 0; i < 4; i++) scanf(\"%lf %lf\", &x[i], &y[i]);\n\n    // Function to calculate the area of a triangle using Heron's formula\n    double calculateArea(double a, double b, double c) {\n        double s = (a + b + c) / 2;\n        return sqrt(s * (s - a) * (s - b) * (s - c));\n    }\n\n    // Function to check if three points are collinear\n    int areCollinear(double x1, double y1, double x2, double y2, double x3, double y3) {\n        return ((x2 - x1) * (y3 - y1) == (x3 - x1) * (y2 - y1));\n    }\n\n    // Generate all combinations of 3 points\n    for (int i = 0; i < 4; i++) {\n        for (int j = i + 1; j < 4; j++) {\n            for (int k = j + 1; k < 4; k++) {\n                double a = sqrt((x[i] - x[j]) * (x[i] - x[j]) + (y[i] - y[j]) * (y[i] - y[j]));\n                double b = sqrt((x[j] - x[k]) * (x[j] - x[k]) + (y[j] - y[k]) * (y[j] - y[k]));\n                double c = sqrt((x[k] - x[i]) * (x[k] - x[i]) + (y[k] - y[i]) * (y[k] - y[i]));\n\n                if (!areCollinear(x[i], y[i], x[j], y[j], x[k], y[k])) {\n                    double area = calculateArea(a, b, c);\n                    printf(\"area %.3f\\n\", area);\n                } else {\n                    printf(\"collinear\\n\");\n                }\n            }\n        }\n    }\n\n    return 0;\n}",
