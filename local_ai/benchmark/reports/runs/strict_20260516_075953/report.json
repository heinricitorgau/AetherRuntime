      "extracted_code": "#include <stdio.h>\n#include <math.h>\n\ndouble calculateArea(double ax, double ay, double bx, double by, double cx, double cy) {\n    double side1 = sqrt((bx - ax) * (bx - ax) + (by - ay) * (by - ay));\n    double side2 = sqrt((cx - bx) * (cx - bx) + (cy - by) * (cy - by));\n    double side3 = sqrt((ax - cx) * (ax - cx) + (ay - cy) * (ay - cy));\n\n    double s = (side1 + side2 + side3) / 2.0;\n    return sqrt(s * (s - side1) * (s - side2) * (s - side3));\n}\n\nint areCollinear(double ax, double ay, double bx, double by, double cx, double cy) {\n    double area = calculateArea(ax, ay, bx, by, cx, cy);\n    return fabs(area) < 1e-9; // Using a small epsilon for floating-point comparison\n}\n\nint main(void) {\n    double x[4], y[4];\n    scanf(\"%lf %lf %lf %lf\", &x[0], &y[0], &x[1], &y[1]);\n    scanf(\"%lf %lf %lf %lf\", &x[2], &y[2], &x[3], &y[3]);\n\n    for (int i = 0; i < 4; i++) {\n        for (int j = i + 1; j < 4; j++) {\n            for (int k = j + 1; k < 4; k++) {\n                double area = calculateArea(x[i], y[i], x[j], y[j], x[k], y[k]);\n                if (area > 0) {\n                    printf(\"area %.3f\\n\", area);\n                } else {\n                    printf(\"collinear\\n\");\n                }\n            }\n        }\n    }\n\n    return 0;\n}",
